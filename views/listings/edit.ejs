<% layout("/layouts/boilerplate.ejs") %>

    <div class="row mt-4">
        <div class="col-8 offset-2">
            <h3 class="new-listing">Edit your listing</h3>
            <br>
    <form action="/listings/<%=listing._id  %>?_method=PUT" method="post" class="needs-validation" novalidate enctype="multipart/form-data">
                <div class="mb-3 ">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" name="listing[title]" value="<%=listing.title%>" class="form-control" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]" class="form-control" required><%=listing.description%></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    Original Image: <br>
                    <img src="<%=listing.image.url%>" alt="Current Image" class="img-thumbnail mb-3" style="max-width: 400px;">
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Upload New Image</label>
                    <input type="file" name="listing[image]" class="form-control">
                </div>

                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" name="listing[country]" value="<%=listing.country%>" class="form-control" required>
                        <div class="invalid-feedback" >
                            Please provide a valid country.
                        </div>
                    </div>
                    <div class="mb-3 col-md-6">
                        <label for="category" class="form-label">Category</label>
                        <select name="listing[category]" class="form-select form-control" required>
                            <option value="heritage" <%= listing.category === 'heritage' ? 'selected' : '' %>>Heritage</option>
                            <option value="nature" <%= listing.category === 'nature' ? 'selected' : '' %>>Nature</option>
                            <option value="spiritual" <%= listing.category === 'spiritual' ? 'selected' : '' %>>Spiritual</option>
                            <option value="food" <%= listing.category === 'food' ? 'selected' : '' %>>Food</option>
                            <option value="adventure" <%= listing.category === 'adventure' ? 'selected' : '' %>>Gallery / Adventure</option>
                            <option value="other" <%= listing.category === 'other' ? 'selected' : '' %>>Stays / Other</option>
                        </select>
                         <div class="invalid-feedback">
                            Please provide a valid category.
                        </div>
                    </div>
                </div>
                <div class="mb-4">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" name="listing[location]" value="<%=listing.location%>" class="form-control"
                    required>
                    <div class="invalid-feedback">
                        Please provide a valid location.
                    </div>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label for="latitude" class="form-label">Latitude (Optional)</label>
                        <input type="number" step="any" name="listing[latitude]" value="<%=listing.latitude%>" placeholder="e.g. 40.7128" class="form-control">
                        <div class="form-text text-muted small">Providing exact latitude speeds up map placement.</div>
                    </div>
                    <div class="mb-3 col-md-6">
                        <label for="longitude" class="form-label">Longitude (Optional)</label>
                        <input type="number" step="any" name="listing[longitude]" value="<%=listing.longitude%>" placeholder="e.g. -74.0060" class="form-control">
                    </div>
                </div>

                <button class="btn btn-primary">Edit</button>
            </form>
        </div>
    </div>